# ==========================================================
# .gitignore — Livskin RevOps central hub
# Evita commits de: secretos, claves, data local, código ajeno
# ==========================================================

# --- Secretos y credenciales ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# --- Claves SSH ---
.ssh/
*.ppk

# --- Claves y tokens locales del proyecto ---
# Ignorar TODO en keys/ por defecto...
keys/*
# ...excepto estos archivos no-sensibles (IPs y paths, sin claves ni tokens)
!keys/ssh_config
!keys/ssh_config.example
!keys/README.md
!keys/.gitkeep

# --- ERP Livskin (repo separado, clonado aquí solo local) ---
# Nunca subir código del ERP a este repo; tiene su propio repo GitHub
erp/

# --- Data operativa (no pertenece al repo) ---
data/
db/

# --- Backups pulled localmente (pueden ser grandes) ---
/backups/
!/backups/.gitkeep
# Nota: solo `/backups/` en raíz se ignora — `infra/scripts/backups/` SÍ se versiona

# --- Docker volumes y caches ---
**/volumes/
**/.docker-compose-override.yml

# --- Extracciones temporales ---
docs/datos_livskin_extract/
docs/pensamientos.txt

# --- Data REAL con PII (nombres, teléfonos, ventas, etc.) ---
# Exports frescos del Sheets — viven LOCAL + VPS 3, NUNCA en GitHub
docs/Datos_Livskin_*.xlsx
# El "Datos Livskin.xlsx" viejo (sin guion bajo, sin fecha) ya está commiteado;
# se mantiene como referencia histórica anonimizada por el paso del tiempo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Obsidian vault (workspace personal) ---
.obsidian/
*.obsidian
*.obsidian-cache
# Obsidian canvas vacios accidentales (New > Canvas sin renombrar)
Senza nome*.canvas
Untitled*.canvas

# --- Notas privadas del usuario (por máquina, no se comparten) ---
notes/privado/*
!notes/privado/README.md

# --- Claude Code local config ---
.claude/

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# --- Node ---
node_modules/
dist/
build/

# --- Coverage / testing ---
.coverage
htmlcov/
.pytest_cache/

