# n8n env vars — copiar a `.env` en VPS 2 con valores reales
#
# Source de los secrets reales: keys/.env.integrations (laptop, gitignored)
# La copia al VPS 2 va en /home/livskin/apps/n8n/.env (gitignored, en VPS).
#
# Ver infra/n8n/conventions.md § 9 para política de credenciales.

# ─────────────────────────────────────────────────────────────────────
# n8n core (overrides — dejar vacío para usar defaults del compose)
# ─────────────────────────────────────────────────────────────────────
N8N_HOST=flow.livskin.site
N8N_WEBHOOK_URL=https://flow.livskin.site

# ─────────────────────────────────────────────────────────────────────
# Vtiger CRM (consumido por workflows [A1], [B1], futuro [B2], [G1], [G2])
# ─────────────────────────────────────────────────────────────────────
VTIGER_URL=https://crm.livskin.site
VTIGER_API_USER=admin
VTIGER_API_ACCESSKEY=<bitwarden:vtiger-api-accesskey>

# ─────────────────────────────────────────────────────────────────────
# ERP audit endpoint (consumido por la mayoría de workflows)
# ─────────────────────────────────────────────────────────────────────
AUDIT_INTERNAL_TOKEN=<obtener de VPS 3 /srv/livskin-revops/keys/.audit-internal-token>
ERP_AUDIT_URL=https://erp.livskin.site/api/internal/audit-event

# ─────────────────────────────────────────────────────────────────────
# n8n control flags — NO secretos, pero requeridos para que workflows funcionen
# ─────────────────────────────────────────────────────────────────────
# Permitir acceso a env vars ($env.*) desde nodos HTTP Request + Code.
# n8n bloquea esto por default por seguridad (defense in depth).
# Necesario para workflows que referencan {{ $env.VTIGER_URL }} etc.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Permitir require() de built-ins específicos en Code nodes.
# Workflows que usan crypto (md5 para Vtiger login) requieren esto.
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# Persistir execution data — necesario para debugging + observabilidad
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# ─────────────────────────────────────────────────────────────────────
# Futuros (Fase 4+)
# ─────────────────────────────────────────────────────────────────────
# WHATSAPP_PHONE_NUMBER_ID=<bitwarden:wa-phone-id>
# WHATSAPP_ACCESS_TOKEN=<bitwarden:wa-access-token>
# WHATSAPP_VERIFY_TOKEN=<bitwarden:wa-verify-token>
# CLAUDE_API_KEY=<bitwarden:claude-api-key>
