# ERP Flask — variables de entorno (template, no commitear .env real)
# Las contraseñas reales viven en infra/docker/postgres-data/.env

ERP_DB_USER=erp_user
ERP_DB_NAME=livskin_erp
ERP_DB_HOST=postgres-data
ERP_DB_PORT=5432
# ERP_DB_PASSWORD viene de postgres-data/.env

FLASK_SECRET_KEY=change-me-in-production-with-secrets.token_hex
FLASK_ENV=production

SESSION_DURATION_HOURS=48
SESSION_INACTIVITY_HOURS=2
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_MINUTES=15

LOG_LEVEL=INFO
