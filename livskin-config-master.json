  "build_consumers": {
    "_purpose": "Lista de qué procesos LEEN este config y propagan los valores",
    "consumers": [
      {
        "consumer": "infra/wordpress/mu-plugins/livskin-form-to-n8n.php",
        "fields_used": ["contacts.doctora.phone_e164", "treatments[].form_dropdown_value", "tracking.pixel_meta.active_id"],
        "method": "manual edit on changes (no auto-build yet)"
      },
      {
        "consumer": "infra/landing-pages/_shared/livskin-tracking.js",
        "fields_used": ["contacts.doctora.phone_e164", "tracking.pixel_meta.active_id", "domains.cookie_scope_root", "compliance.consent_required_for_marketing_cookies"],
        "method": "GitHub Actions build process (Mini-bloque 3.6.5)"
      },
      {
        "consumer": "n8n env vars (.env on VPS 2)",
        "fields_used": ["tracking.pixel_meta.active_id", "tracking.pixel_meta.business_manager_id"],
        "method": "manual sync (consider n8n config fetch endpoint en F5+)"
      },
      {
        "consumer": "ERP Flask config",
        "fields_used": ["integrations.n8n_webhook_capi_emit", "compliance.data_retention_years"],
        "method": "Pydantic Settings env vars (futuro: read from this JSON)"
      },
      {
        "consumer": "docs/legal/*.md",
        "fields_used": ["business.*", "contacts.*", "compliance.*", "domains.*"],
        "method": "manual edit on changes"
      }
    ]
  },

